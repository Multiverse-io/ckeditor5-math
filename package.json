{
  "name": "@multiverse-io/ckeditor5-math",
  "version": "47.6.1-next.0",
  "description": "Math feature for CKEditor 5.",
  "keywords": [
    "ckeditor",
    "ckeditor5",
    "ckeditor 5",
    "ckeditor5-feature",
    "ckeditor5-plugin",
    "ckeditor5-package-generator",
    "ckeditor5-math",
    "katex"
  ],
  "publishConfig": {
    "@multiverse-io:registry": "https://npm.pkg.github.com"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./*": "./dist/*",
    "./browser/*": null,
    "./package.json": "./package.json"
  },
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.11.0",
    "npm": ">=5.7.1"
  },
  "files": [
    "dist",
    "ckeditor5-metadata.json"
  ],
  "devDependencies": {
    "@ckeditor/ckeditor5-dev-build-tools": "55.3.0",
    "@ckeditor/ckeditor5-dev-translations": "55.3.0",
    "@ckeditor/ckeditor5-inspector": "^5.0.0",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitest/browser-webdriverio": "^4.1.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "ckeditor5": "^47.6.1",
    "eslint": "^9.27.0",
    "eslint-config-ckeditor5": "^14.0.0",
    "eslint-plugin-ckeditor5-rules": "^14.0.0",
    "globals": "^17.4.0",
    "husky": "^4.2.5",
    "lint-staged": "^10.2.6",
    "stylelint": "^16.0.0",
    "stylelint-config-ckeditor5": "^14.0.0",
    "typescript": "5.5.4",
    "vite": "^8.0.3",
    "vite-plugin-svgo": "^2.0.0",
    "vitest": "^4.1.2",
    "webdriverio": "^9.27.0"
  },
  "peerDependencies": {
    "ckeditor5": ">=47.0.0"
  },
  "resolutions": {
    "tar": "^7.5.3",
    "webpack": "^5.104.1",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.23",
    "qs": "^6.14.1",
    "node-forge": "^1.3.2",
    "js-yaml": "^4.1.1",
    "tmp": "^0.2.4",
    "on-headers": "^1.1.0",
    "webpack-dev-server": "^5.2.1",
    "http-proxy-middleware": "^3.0.5",
    "cross-spawn": "^7.0.5",
    "rollup": "^4.59.0",
    "flatted": "^3.4.2",
    "@babel/helpers": "^7.26.10"
  },
  "scripts": {
    "start": "vite",
    "build": "yarn run build:types && yarn run build:npm && yarn run build:browser",
    "build:npm": "vite build --mode npm",
    "build:browser": "vite build --mode browser",
    "build:types": "tsc -p tsconfig.build.json",
    "lint": "eslint . --quiet",
    "stylelint": "stylelint --quiet --allow-empty-input 'theme/**/*.css'",
    "test": "vitest",
    "test:debug": "vitest --inspect-brk --no-file-parallelism --browser.headless=false",
    "translations:synchronize": "node ./scripts/synchronize-translations.js",
    "translations:validate": "node ./scripts/synchronize-translations.js --validate-only",
    "prepublishOnly": "yarn run build"
  },
  "lint-staged": {
    "**/*.{js,ts}": [
      "eslint --quiet"
    ],
    "**/*.css": [
      "stylelint --quiet --allow-empty-input"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
